# Database Configuration
# These are automatically provided by Railway's MySQL plugin if deployed there
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=your_mysql_password
MYSQLDATABASE=codearena

# Fallback environment variables if not using Vercel/Railway default conventions
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT Authentication secret
JWT_SECRET=your_super_secret_jwt_key

# Express listener port (local dev only, ignored on Vercel)
PORT=5001

# Gemini AI Integration (optional, for code coaching hints)
GEMINI_API_KEY=your_gemini_api_key
