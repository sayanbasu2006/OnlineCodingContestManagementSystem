# Database Configuration (PostgreSQL)
# Provide EITHER a unified connection string (DATABASE_URL) OR individual connection parameters.
# DATABASE_URL is automatically provided by Vercel/Neon integrations.
DATABASE_URL=postgresql://postgres:password@localhost:5432/codearena

# Individual PostgreSQL connection parameters (optional fallback)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=codearena

# JWT Authentication secret (Required)
JWT_SECRET=your_super_secret_jwt_key

# Express listener port (local dev only, ignored on Vercel)
PORT=5001

# Gemini AI Integration (optional, for code coaching hints)
GEMINI_API_KEY=your_gemini_api_key

