# PostgreSQL connection (use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://user:password@host:5432/codearena?sslmode=require
# OR individual vars for local development:
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=codearena
# DB_PORT=5432

# Auth
JWT_SECRET=your_long_random_secure_jwt_secret_key

# Server
PORT=5001

# AI (optional)
GEMINI_API_KEY=your_gemini_api_key

# CORS (production — set to your Vercel URL)
FRONTEND_URL=https://your-app.vercel.app
